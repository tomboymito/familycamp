# ── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Node / npm ───────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build outputs ────────────────────────────────────
dist/
dist-ssr/
build/
out/
.next/
.nuxt/

# ── TypeScript ───────────────────────────────────────
*.tsbuildinfo

# ── Env / secrets ────────────────────────────────────
.env
.env.local
.env.*.local
# keep .env.example committed
!.env.example

# ── Logs ─────────────────────────────────────────────
logs/
*.log

# ── IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# ── Testing / coverage ───────────────────────────────
coverage/
.nyc_output/

# ── Docker ───────────────────────────────────────────
# (keep docker-compose files — they're config, not secrets)

# ── Misc ─────────────────────────────────────────────
*.pem
*.key
*.cert
