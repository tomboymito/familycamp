# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=autocamping
POSTGRES_USER=autocamping
POSTGRES_PASSWORD=changeme

# JWT
JWT_SECRET=changeme_jwt_secret_min32chars_change_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=changeme_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Backend
NODE_ENV=production
BACKEND_PORT=3000
API_PREFIX=api/v1

# Frontend URLs (for CORS)
PUBLIC_SITE_URL=http://localhost
ADMIN_URL=http://localhost/admin

# Frontend env
# В dev через nginx лучше использовать относительный путь к API,
# чтобы избежать CORS/портовых рассинхронов.
NEXT_PUBLIC_API_URL=/api/v1
VITE_API_URL=/api/v1

# Nginx
NGINX_PORT=80

# Payment (mock in v1)
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=webhook-secret-change-in-production

# Yandex Maps
YANDEX_MAPS_API_KEY=your-yandex-maps-api-key

# Hold TTL (minutes)
HOLD_TTL_MINUTES=15
